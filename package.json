{
  "name": "meteora-dlmm-bot",
  "version": "2.0.0",
  "description": "Autonomous Meteora DLMM AI Agent — Telegram + Hunter/Healer loop",
  "main": "src/index.js",
  "type": "module",
  "scripts": {
    "start": "node src/index.js",
    "dev": "DRY_RUN=true node --watch src/index.js",
    "dry": "DRY_RUN=true node src/index.js",
    "test": "node --test tests/*.test.js",
    "test:coverage": "c8 --reporter=text-summary --reporter=lcov node --test tests/*.test.js",
    "lint": "node scripts/lint.js",
    "check": "npm run lint && npm run test",
    "postinstall": "patch-package && node scripts/ensure-anchor-esm.js"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.39.0",
    "@meteora-ag/dlmm": "^1.3.9",
    "@solana/web3.js": "^1.98.0",
    "better-sqlite3": "^9.6.0",
    "bn.js": "^5.2.1",
    "bs58": "^6.0.0",
    "dotenv": "^16.4.5",
    "node-cron": "^3.0.3",
    "node-telegram-bot-api": "^0.66.0",
    "openai": "^6.33.0"
  },
  "devDependencies": {
    "c8": "^10.1.3",
    "patch-package": "^8.0.1"
  }
}
