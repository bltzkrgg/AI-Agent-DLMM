# ─── Telegram ────────────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here
ALLOWED_TELEGRAM_ID=your_telegram_user_id_here

# ─── AI Provider ─────────────────────────────────────────────────
# Pilih salah satu: anthropic | openrouter | openai | custom
AI_PROVIDER=anthropic

# Model (opsional — kalau tidak di-set, pakai default per provider)
# Anthropic:   claude-sonnet-4-20250514
# OpenRouter:  anthropic/claude-sonnet-4  |  openai/gpt-4o  |  google/gemini-2.0-flash  |  deepseek/deepseek-r1
# OpenAI:      gpt-4o  |  gpt-4o-mini
# AI_MODEL=claude-sonnet-4-20250514

# API Keys — isi sesuai provider yang dipilih
ANTHROPIC_API_KEY=       # kalau AI_PROVIDER=anthropic
OPENROUTER_API_KEY=      # kalau AI_PROVIDER=openrouter
OPENAI_API_KEY=          # kalau AI_PROVIDER=openai

# Custom provider (opsional)
# CUSTOM_AI_BASE_URL=https://your-custom-endpoint/v1
# CUSTOM_AI_API_KEY=your_key

# ─── Solana ──────────────────────────────────────────────────────
# HELIUS (wajib) — RPC utama + on-chain data real-time
# Daftar di: https://helius.dev → Dashboard → API Keys
HELIUS_API_KEY=your_helius_api_key_here

# Override RPC URL (opsional — kalau mau pakai Helius dedicated node / devnet)
# Default: https://mainnet.helius-rpc.com/?api-key=<HELIUS_API_KEY>
# HELIUS_RPC_URL=https://your-dedicated-node.helius-rpc.com

# Fallback RPC (kalau HELIUS_API_KEY tidak di-set — tidak direkomendasikan)
# SOLANA_RPC_URL=https://api.mainnet-beta.solana.com

# WAJIB: gunakan wallet KHUSUS bot, bukan wallet utama!
WALLET_PRIVATE_KEY=your_wallet_private_key_base58_here

# ─── Bot Config ──────────────────────────────────────────────────
# Password untuk /addstrategy, /deletestrategy
ADMIN_PASSWORD=your_strong_password_here

# On-chain Intelligence (opsional tapi direkomendasikan)
OKX_API_KEY=                # dari OKX OnchainOS — smart money signals & token risk scoring (okx.com/web3)

# Test/runtime overrides (opsional)
# BOT_CONFIG_PATH=/absolute/path/to/user-config.json
# BOT_DB_PATH=/absolute/path/to/data.db
# BOT_RUNTIME_STATE_PATH=/absolute/path/to/runtime-state.json
